edk2_port/edk2-rockchip/arm-trusted-firmware/

# Device-tree vendor blobs and upstream mirror (cloned/built at build time;
# gigabytes of Rockchip DTBs not worth tracking)
edk2_port/edk2-rockchip/devicetree/vendor/
edk2_port/edk2-rockchip/devicetree/mainline/upstream/
# RK3588 community platform DTS overlays (not our target SoC)
edk2_port/edk2-rockchip/devicetree/mainline/rk3588*
# (rk3576-rock-4d.dts symlink and rk3576-rock-4d-uefi.dts ARE tracked)

