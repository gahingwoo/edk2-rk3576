[Defines]
  INF_VERSION    = 0x0001001a
  BASE_NAME      = RK3576Dxe
  FILE_GUID      = a2b3c4d5-e6f7-4081-9192-a3b4c5d6e7f8
  MODULE_TYPE    = DXE_DRIVER
  VERSION_STRING = 1.0
  ENTRY_POINT    = RK3576EntryPoint

[Sources]
  RK3576Dxe.c

[Packages]
  ArmPkg/ArmPkg.dec
  ArmPlatformPkg/ArmPlatformPkg.dec
  EmbeddedPkg/EmbeddedPkg.dec
  MdeModulePkg/MdeModulePkg.dec
  MdePkg/MdePkg.dec
  Silicon/Rockchip/RockchipPkg.dec
  Silicon/Rockchip/RK3576/RK3576.dec
  Silicon/Rockchip/RK3588/RK3588.dec

[LibraryClasses]
  DebugLib
  IoLib
  BaseMemoryLib
  UefiBootServicesTableLib
  UefiRuntimeServicesTableLib
  UefiLib
  UefiDriverEntryPoint
  DxeServicesTableLib
  RK806
  CruLib
  ArmLib
  PcdLib
  RockchipPlatformLib

[Protocols]
  gEfiVariableWriteArchProtocolGuid         ## CONSUMES
  gRockchipPlatformConfigAppliedProtocolGuid ## PRODUCES

[Pcd]
  gRockchipTokenSpaceGuid.CruBaseAddr
  gRK3576TokenSpaceGuid.PcdCPULClusterClockPresetDefault
  gRK3576TokenSpaceGuid.PcdCPUBClusterClockPresetDefault
  gRK3576TokenSpaceGuid.PcdComboPhy0Switchable
  gRK3576TokenSpaceGuid.PcdComboPhy1Switchable
  gRK3576TokenSpaceGuid.PcdComboPhy0ModeDefault
  gRK3576TokenSpaceGuid.PcdComboPhy1ModeDefault
  gRK3576TokenSpaceGuid.PcdConfigTableModeDefault
  gRK3576TokenSpaceGuid.PcdFdtCompatModeDefault
  gRK3576TokenSpaceGuid.PcdFdtForceGopDefault
  gRK3576TokenSpaceGuid.PcdFdtSupportOverridesDefault
  gRK3576TokenSpaceGuid.PcdFdtOverrideFixupDefault
  gRK3576TokenSpaceGuid.PcdStatusLedGpio
  gRK3576TokenSpaceGuid.PcdStatusLedGpioPolarity
  gRK3576TokenSpaceGuid.PcdDisplayConnectors
  gRK3576TokenSpaceGuid.PcdDisplayForceOutputDefault
  gRK3576TokenSpaceGuid.PcdDisplayDuplicateOutputDefault
  gRK3588TokenSpaceGuid.PcdDisplayConnectorsMask
  gRK3588TokenSpaceGuid.PcdHdmiSignalingMode

[Guids]
  gRK3576DxeFormSetGuid

[Depex]
  TRUE
