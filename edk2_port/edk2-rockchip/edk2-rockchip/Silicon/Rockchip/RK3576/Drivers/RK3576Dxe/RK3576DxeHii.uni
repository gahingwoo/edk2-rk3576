#string STR_DISPLAY_CONNECTORS_PRIORITY_PROMPT             #language en-US "Output Priority"
#string STR_DISPLAY_CONNECTORS_PRIORITY_HELP               #language en-US "Order in which display outputs are activated. The first connector with a connected display will be used as the primary output."

#string STR_DISPLAY_CONNECTOR_HDMI0                        #language en-US "HDMI0"
#string STR_DISPLAY_CONNECTOR_HDMI1                        #language en-US "HDMI1"
