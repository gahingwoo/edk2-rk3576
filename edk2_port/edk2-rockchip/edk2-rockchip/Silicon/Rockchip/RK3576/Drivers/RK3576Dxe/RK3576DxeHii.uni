#string STR_DISPLAY_FORCE_OUTPUT_PROMPT                    #language en-US "Force Output"
#string STR_DISPLAY_FORCE_OUTPUT_HELP                      #language en-US "Force display output even when no monitor is detected (HPD low). Useful for headless setups or displays that do not assert HPD."

#string STR_DISPLAY_DUPLICATE_OUTPUT_PROMPT                #language en-US "Duplicate Output"
#string STR_DISPLAY_DUPLICATE_OUTPUT_HELP                  #language en-US "Duplicate the primary output to all detected displays."

#string STR_DISPLAY_ROTATION_PROMPT                        #language en-US "Screen Rotation"
#string STR_DISPLAY_ROTATION_HELP                          #language en-US "Rotate the display output clockwise."
#string STR_DISPLAY_ROTATION_0                             #language en-US "0\u00b0 (Normal)"
#string STR_DISPLAY_ROTATION_90                            #language en-US "90\u00b0 Clockwise"

#string STR_HDMI_SIGNALING_MODE_PROMPT                     #language en-US "HDMI Signaling"
#string STR_HDMI_SIGNALING_MODE_HELP                       #language en-US "Choose the HDMI signaling protocol.\n\nAuto - use HDMI if the monitor supports it, otherwise fall back to DVI.\nDVI - force DVI-compatible signaling (no audio, no advanced HDMI features).\nHDMI - force full HDMI signaling."
#string STR_HDMI_SIGNALING_MODE_AUTO                       #language en-US "Auto"
#string STR_HDMI_SIGNALING_MODE_DVI                        #language en-US "DVI"
#string STR_HDMI_SIGNALING_MODE_HDMI                       #language en-US "HDMI"

/*
 * ComboPHY mode configuration
 */

#string STR_COMBO_PHY_FORM_TITLE                           #language en-US "ComboPHY Mode"
#string STR_COMBO_PHY_FORM_HELP                            #language en-US "Configure the Naneng Combo PHY controllers."
#string STR_COMBO_PHY_FORM_SUBTITLE                        #language en-US "Changes take effect after reboot."

#string STR_COMBO_PHY0_MODE_PROMPT                         #language en-US "ComboPHY0 (M.2 PCIe)"
#string STR_COMBO_PHY1_MODE_PROMPT                         #language en-US "ComboPHY1 (USB Type-A)"

#string STR_COMBO_PHY_MODE_DEFAULT_PCIE_HELP               #language en-US "Configure PHY mode. Default: PCIe.\n\nUnconnected - disable the PHY (saves power).\nPCIe - standard PCIe lane."
#string STR_COMBO_PHY_MODE_DEFAULT_USB3_HELP               #language en-US "Configure PHY mode. Default: USB 3.0.\n\nUnconnected - disable the PHY.\nPCIe - use as PCIe lane instead of USB3 (loses USB3 SuperSpeed on this port).\nUSB 3.0 - standard SuperSpeed USB."
#string STR_COMBO_PHY_MODE_DEFAULT_UNCONNECTED_HELP        #language en-US "Configure PHY mode. Default: Unconnected.\n\nThe PHY is not connected to any interface on this board."

#string STR_COMBO_PHY_MODE_UNCONNECTED                     #language en-US "Unconnected"
#string STR_COMBO_PHY_MODE_PCIE                            #language en-US "PCIe"
#string STR_COMBO_PHY_MODE_USB3                            #language en-US "USB 3.0"
