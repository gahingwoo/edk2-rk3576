##

[Defines]
  INF_VERSION                    = 1.29
  BASE_NAME                      = ResetSystemLib
  FILE_GUID                      = 5C2E4A3F-1B8D-4F72-9A6E-0D3E7C8B5129
  MODULE_TYPE                    = BASE
  VERSION_STRING                 = 1.0
  LIBRARY_CLASS                  = ResetSystemLib
  CONSTRUCTOR                    = ResetSystemLibConstructor

[Sources]
  ResetSystemLib.c

[Packages]
  ArmPkg/ArmPkg.dec
  MdeModulePkg/MdeModulePkg.dec
  MdePkg/MdePkg.dec
  Silicon/Rockchip/RockchipPkg.dec

[LibraryClasses]
  ArmMonitorLib
  BaseLib
  BaseMemoryLib
  DebugLib
  IoLib
  ResetUtilityLib

[Guids]
  gRockchipResetTypeMaskromGuid
