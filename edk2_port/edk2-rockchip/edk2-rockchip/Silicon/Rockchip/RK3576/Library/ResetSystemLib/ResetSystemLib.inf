## @file
#  ResetSystem library for RK3576 — PSCI with MaskROM boot mode support.
#
#  Boot mode register: PMU0_GRF_OS_REG16 = 0x26024040
#    (PMU0_GRF_BASE=0x26024000 + OS_REG(16)=0x40)
#  Source: U-Boot mainline rk3576/Kconfig ROCKCHIP_BOOT_MODE_REG = 0x26024040
#          TF-A plat/rockchip/rk3576/drivers/pmu/pmu.h PMU0GRF_OS_REG(16)
