#/** @file
#
#  ArmSoM CM5-IO Vendor Device Tree (pre-compiled DTB from ArmSoM BSP kernel)
#
#  To use this INF:
#    1. Obtain rk3576-armsom-cm5-rpi-cm4-io.dtb from the ArmSoM rockchip-kernel
#       (branch: linux-6.1-stan-rkr6.1, arch/arm64/boot/dts/rockchip/)
#    2. Place the DTB at:
#       devicetree/vendor/rk3576-armsom-cm5-rpi-cm4-io.dtb
#    3. Uncomment the Vendor.inf line in CM5RpiCM4IO.Modules.fdf.inc
#    4. Uncomment the $(PLATFORM_DIRECTORY)/DeviceTree/Vendor.inf line
#       in the [Components.common] section of CM5RpiCM4IO.dsc
#
#  Copyright (c) 2025, ArmSoM CM5-IO EDK2 Port
#  SPDX-License-Identifier: BSD-2-Clause-Patent
#
#**/

[Defines]
  INF_VERSION                    = 0x0001001A
  BASE_NAME                      = DeviceTree-Vendor
  FILE_GUID                      = d4e5f6a7-b8c9-4d0e-1f2a-3b4c5d6e7f80
  MODULE_TYPE                    = USER_DEFINED
  VERSION_STRING                 = 1.0

[Binaries]
  BIN|devicetree/vendor/rk3576-armsom-cm5-rpi-cm4-io.dtb
